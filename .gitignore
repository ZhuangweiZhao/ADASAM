# ── Python ──
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.ipynb_checkpoints/

# ── Model weights (large binaries, fetched via tools/setup_mobilesam.py) ──
*.pt
*.pth
!thirdparty/**/*.pt
weights/*.pt
thirdparty/MobileSAM/weights/*.pt

# ── Datasets (external, not tracked) ──
data/

# ── Experiment outputs ──
runs/
output/
*.jsonl
!tests/**/*.jsonl

# ── Docs & notes ──
docs/

# ── OS / editor ──
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~

# ── Third-party vendored code (kept as-is) ──
thirdparty/cat-sam/
thirdparty/Mask2Former/
